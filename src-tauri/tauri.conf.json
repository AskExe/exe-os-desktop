{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Exe OS",
  "version": "0.1.0",
  "identifier": "com.askexe.exe-os",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Exe OS",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://askexe.com/api/updates/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQzN0IwQzBGOEZERjA1N0EKUldSNkJkK1BEd3g3UXpsd3JNQkt5b0VRQU9ZWUMxTXBlRFlXcnNYWGNmTXd0NEhXbk1Mc0JudmwK"
    }
  }
}
